# ============================================================
# Database
# ============================================================
DB_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# ============================================================
# JWT Secrets
# Generate with: openssl rand -hex 64
# ============================================================
SECRET_KEY=change_me_generate_with_openssl_rand_hex_64
REFRESH_SECRET_KEY=change_me_generate_with_openssl_rand_hex_64

# ============================================================
# Optional settings
# ============================================================

# Allow new user registration (set to false after initial setup)
ALLOW_REGISTRATION=true

# Allowed CORS origin (your domain or http://localhost)
CORS_ORIGIN=http://localhost
