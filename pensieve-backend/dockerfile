# Этап 1: Сборка
FROM node:22.17.0-alpine AS builder

WORKDIR /app

# 1. Копируем зависимости
COPY package*.json ./

# 2. Устанавливаем ВСЕ зависимости (включая dev)
RUN npm install --no-audit --silent

# 3. Копируем исходный код
COPY . .

# 4. Выполняем сборку
RUN npm run build

# Этап 2: Финальный образ
FROM node:22.17.0-alpine

# Создаем непривилегированного пользователя
RUN addgroup -g 1001 -S appgroup && \
    adduser -u 1001 -S appuser -G appgroup

ENV APP_ROOT=/express
ENV PORT=5000
ENV NODE_ENV=production

WORKDIR ${APP_ROOT}

# Копируем продакшн-зависимости
COPY --from=builder /app/package*.json ./
RUN npm install --only=production --no-audit --silent && \
    npm cache clean --force

# Копируем собранный код из предыдущего этапа
COPY --from=builder --chown=appuser:appgroup /app/dist ./dist

# Порт приложения
EXPOSE ${PORT}

# Создаём папку для загрузок и передаём права до смены пользователя
RUN mkdir -p uploads && chown appuser:appgroup uploads

# Переключаемся на непривилегированного пользователя
USER appuser

CMD ["node", "dist/app.js"]